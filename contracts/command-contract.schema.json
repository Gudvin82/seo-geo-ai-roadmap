{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gudvin82.github.io/seo-geo-ai-roadmap/contracts/command-contract.schema.json",
  "title": "Command Contract",
  "type": "object",
  "required": ["contract_version", "canonical_prefix", "routes"],
  "properties": {
    "contract_version": { "type": "string" },
    "canonical_prefix": { "type": "string" },
    "canonical_sequence": { "type": "array", "items": { "type": "string" } },
    "product_modes": { "type": "array", "items": { "type": "string" } },
    "ci_first_class": { "type": "boolean" },
    "routes": { "type": "array", "items": { "type": "object" } },
    "integration_touchpoints": { "type": "array", "items": { "type": "string" } }
  }
}
