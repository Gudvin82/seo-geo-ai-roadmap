{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gudvin82.github.io/seo-geo-ai-roadmap/contracts/task-bundle.schema.json",
  "title": "Task Bundle Contract",
  "type": "object",
  "required": ["contract_version", "source_type", "source_id", "tasks"],
  "properties": {
    "contract_version": { "type": "string" },
    "source_type": { "type": "string" },
    "source_id": { "type": "string" },
    "summary": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "issue_type", "severity", "recommended_fix"],
        "properties": {
          "id": { "type": "string" },
          "issue_type": { "type": "string" },
          "severity": { "type": "string" },
          "affected_surface": { "type": "string" },
          "affected_pages": { "type": "array", "items": { "type": "string" } },
          "recommended_fix": { "type": "string" },
          "workflow": { "type": "string" },
          "suggested_owner": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "estimated_impact": { "type": "string" },
          "status": { "type": "string" },
          "source_ref": { "type": "string" }
        }
      }
    }
  }
}
