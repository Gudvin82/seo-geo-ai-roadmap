# Never use sample defaults in production.
# Replace all placeholder values before exposing the app to the public internet.

# Repository-level optional AI credentials.
# The methodology layer remains usable without them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
VLLM_API_KEY=

# Optional helper-script routing.
AI_PROVIDER=
AI_MODEL=

# Optional local/self-hosted AI providers.
OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=llama3.1
LOCALAI_BASE_URL=http://localhost:8080/v1/chat/completions
LOCALAI_MODEL=llama3.1
VLLM_BASE_URL=http://localhost:8001/v1/chat/completions
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
PROVIDER_TIMEOUT_SECONDS=30

# App layer settings.
APP_SECRET_KEY=replace-with-32-byte-random-secret
APP_DATABASE_URL=sqlite:///./app/backend/data/discoverability.db
APP_ARTIFACT_ROOT=./app/backend/artifacts
APP_DEFAULT_REPORT_LANGUAGE=en
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
APP_TOKEN_TTL_MINUTES=720
APP_LOGIN_ATTEMPT_WINDOW_SECONDS=900
APP_LOGIN_ATTEMPT_LIMIT=5
APP_AUTO_CREATE_SCHEMA=true
ALLOW_PUBLIC_INTAKE=false
ALLOW_ANONYMOUS_SUBMISSION=false
ALLOW_ACTIVE_SCAN=false
SCANNER_TELEGRAM_BOT_TOKEN=
SCANNER_TELEGRAM_WEBHOOK_SECRET=

# Docker / PostgreSQL defaults.
POSTGRES_DB=discoverability
POSTGRES_USER=discoverability
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Optional docs or distribution settings.
SITE_BASE_URL=
DOCS_SITE_URL=
ENABLE_GITHUB_PAGES=false
