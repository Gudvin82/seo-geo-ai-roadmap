# Never use sample placeholders in production without replacing them first.
# This file documents the minimum safer production-style contract.

OPENAI_API_KEY=replace-if-you-use-openai
ANTHROPIC_API_KEY=replace-if-you-use-anthropic
GEMINI_API_KEY=replace-if-you-use-gemini
PERPLEXITY_API_KEY=replace-if-you-use-perplexity

APP_SECRET_KEY=replace-with-32-byte-random-secret
APP_DATABASE_URL=postgresql://discoverability:replace-with-strong-password@db:5432/discoverability
APP_ARTIFACT_ROOT=/var/lib/discoverability/artifacts
APP_DEFAULT_REPORT_LANGUAGE=en
APP_CORS_ORIGINS=https://your-frontend-domain.example
APP_TOKEN_TTL_MINUTES=720
APP_LOGIN_ATTEMPT_WINDOW_SECONDS=900
APP_LOGIN_ATTEMPT_LIMIT=5
APP_AUTO_CREATE_SCHEMA=false

POSTGRES_DB=discoverability
POSTGRES_USER=discoverability
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
